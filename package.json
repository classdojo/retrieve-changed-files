{
  "name": "retrieve-changed-files",
  "description": "GitHub action that retrieves all changed files in a pull request or push.",
  "version": "3.0.0",
  "private": true,
  "author": "MASES s.r.l. (original author Jitterbit, Inc.)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masesgroup/retrieve-changed-files.git"
  },
  "homepage": "https://github.com/masesgroup/retrieve-changed-files#readme",
  "bugs": {
    "url": "https://github.com/masesgroup/retrieve-changed-files/issues"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "TypeScript",
    "JavaScript",
    "Get",
    "Changed",
    "Modified",
    "Diff",
    "Files"
  ],
  "main": "lib/main.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist/**/* lib/**/*",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check \"{,!(node_modules)/**/}*.ts\"",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build",
    "test": "jest",
    "all": "npm run clean && npm run build && npm run format && npm run lint && npm run package && npm run test"
  },
  "devDependencies": {
    "@octokit/rest": "^20.1.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.57.1",
    "eslint-plugin-github": "^4.10.2",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^4.2.5",
    "jest": "^29.7.0",
    "jest-circus": "^29.3.1",
    "js-yaml": "^4.1.1",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1"
  }
}
